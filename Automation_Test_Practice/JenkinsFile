pipeline{
	agent any
	
	tools{
		maven 'Maven3'
	}
	
	stages{
		
		stage ('checkout'){
			steps{
				git branch:'master',
				url:'https://github.com/Sowmithsow/Capstone-Project.git'
			}
		}
		
		stage('Build'){
			steps{
				bat 'mvn clean compile'
			}
		}
		
		stage('Test'){
			steps{
				bat 'mvn test'
			}
		}
	}
	
}